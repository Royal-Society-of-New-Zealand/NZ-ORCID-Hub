FROM rockylinux:9 AS builder

# Enable CRB (needed for some python3.11 build deps)
RUN dnf install -y 'dnf-command(config-manager)' \
 && dnf config-manager --enable crb \
 && dnf install -y epel-release \
 && dnf install -y https://download.postgresql.org/pub/repos/yum/reporpms/EL-9-$(uname -m)/pgdg-redhat-repo-latest.noarch.rpm \
 && dnf install -y --nodocs \
        python3.11 python3.11-devel \
        gcc make \
        httpd-devel apr-devel apr-util-devel \
        libffi-devel openssl-devel \
        zlib-devel bzip2-devel readline-devel sqlite-devel xz-devel \
        git \
 && dnf clean all

COPY requirements.txt /requirements.txt
RUN python3.11 -m venv /app/venv \
 && /app/venv/bin/pip install -U pip setuptools wheel \
 && /app/venv/bin/pip install mod_wsgi psycopg2-binary \
 && /app/venv/bin/pip install -U -r /requirements.txt \
 && /app/venv/bin/pip install 'setuptools<72'


FROM rockylinux:9

ENV LANG=en_US.UTF-8
LABEL maintainer="The University of Auckland" \
      description="NZ ORCiD Hub Application Image - Rocky Linux 9"

ARG http_proxy
ENV http_proxy=${http_proxy} https_proxy=${http_proxy} ftp_proxy=${http_proxy}

RUN dnf install -y 'dnf-command(config-manager)' \
 && dnf install -y epel-release \
 && dnf install -y https://download.postgresql.org/pub/repos/yum/reporpms/EL-9-$(uname -m)/pgdg-redhat-repo-latest.noarch.rpm \
 && if [ "$(uname -m)" = "x86_64" ]; then \
      (curl -fsSL -o /etc/yum.repos.d/shibboleth.repo \
        "https://shibboleth.net/cgi-bin/sp_repo.cgi?platform=rockylinux9" \
       || curl -fsSL -o /etc/yum.repos.d/shibboleth.repo \
        "http://shibboleth.net/cgi-bin/sp_repo.cgi?platform=rockylinux9"); \
    fi \
 && dnf install -y --nodocs --setopt=install_weak_deps=False \
        python3.11 \
        httpd mod_ssl \
        $([ "$(uname -m)" = "x86_64" ] && echo "shibboleth") \
        postgresql15 \
        openssl \
        nmap-ncat \
        initscripts \
 && ln -s /usr/bin/ncat /usr/local/bin/nc \
 && dnf clean all \
 && rm -rf /var/cache/dnf

COPY --from=builder /app/venv /app/venv
ENV PATH="/app/venv/bin:$PATH"

COPY app.wsgi /var/www/orcidhub/
COPY app.conf /etc/httpd/conf.d/ZZ-app.conf
COPY ./conf /conf
COPY run-app /usr/local/bin/run-app
COPY worker.sh /usr/local/bin/worker.sh
COPY scheduler.sh /usr/local/bin/scheduler.sh

RUN /app/venv/bin/mod_wsgi-express module-config > /etc/httpd/conf.modules.d/10-wsgi.conf \
 && rm -f /etc/httpd/conf.d/ssl.conf \
 && mkdir -p /var/run/lock /var/lock/subsys \
 && (mkdir -p /etc/sysconfig && echo 'export LD_LIBRARY_PATH=/opt/shibboleth/lib64:$LD_LIBRARY_PATH' > /etc/sysconfig/shibd) \
 && find /conf -type f -exec sed -i 's/\r$//' {} + \
 && find /usr/local/bin -type f \( -name "run-app" -o -name "*.sh" \) -exec sed -i 's/\r$//' {} + \
 && chmod +x /usr/local/bin/run-app /usr/local/bin/worker.sh /usr/local/bin/scheduler.sh \
              /conf/render_template \
 && (chmod +x /etc/shibboleth/shibd-redhat 2>/dev/null || true)

EXPOSE 80 443
CMD ["run-app"]
